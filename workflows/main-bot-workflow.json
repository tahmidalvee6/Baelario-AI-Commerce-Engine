{
  "nodes": [
    {
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "parameters": {
        "path": "baelario-bot",
        "httpMethod": "POST"
      },
      "position": [200, 300]
    },
    {
      "name": "Normalize",
      "type": "n8n-nodes-base.set",
      "parameters": {
        "values": {
          "string": [
            { "name": "user_id", "value": "={{$json.body.from}}" },
            { "name": "message", "value": "={{$json.body.text}}" },
            { "name": "channel", "value": "whatsapp" }
          ]
        }
      },
      "position": [400, 300]
    },
    {
      "name": "AI Agent",
      "type": "n8n-nodes-base.openai",
      "parameters": {
        "model": "gpt-4o-mini",
        "messages": [
          {
            "role": "system",
            "content": "You are an ecommerce assistant. Extract intent: place_order, track_order, payment, question. Return JSON."
          },
          {
            "role": "user",
            "content": "={{$json.message}}"
          }
        ]
      },
      "position": [600, 300]
    },
    {
      "name": "Switch Intent",
      "type": "n8n-nodes-base.switch",
      "parameters": {
        "property": "={{$json.intent}}",
        "rules": [
          { "value": "place_order" },
          { "value": "track_order" },
          { "value": "payment" }
        ]
      },
      "position": [800, 300]
    }
  ],
  "connections": {}
}
